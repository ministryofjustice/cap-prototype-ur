{% extends "partials/layout.njk" %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% include "partials/errorSummary.njk" %}
      <form class="form" action="{{ paths.HANDOVER_HOLIDAYS_ITEMS_FOR_CHANGEOVER }}" method="post" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
        {% if childProgressCaption %}<span class="govuk-caption-l">{{ childProgressCaption }}</span>{% endif %}
        {{
          govukTextarea({
            label: {
              text: title,
              classes: "govuk-label--l",
              isPageHeading: true
            },
            hint: {
              text: __('handoverAndHolidays.itemsForChangeover.content')
            },
            name: formFields.ITEMS_FOR_CHANGEOVER,
            value: initialItemsForChangeover,
            errorMessage: errors | findError(formFields.ITEMS_FOR_CHANGEOVER)
          })
        }}
        {% if childProgressCaption %}
          <div class="govuk-checkboxes govuk-!-margin-bottom-4" data-module="govuk-checkboxes">
            <div class="govuk-checkboxes__item">
              <input class="govuk-checkboxes__input" id="apply-to-all" name="apply-to-all" type="checkbox" value="yes">
              <label class="govuk-label govuk-checkboxes__label" for="apply-to-all">
                Apply this answer to all children
              </label>
            </div>
          </div>
        {% endif %}
        {{ govukButton({text: __('continue')}) }}
      </form>
      <form
        class="form"
        action="{{ paths.HANDOVER_HOLIDAYS_ITEMS_FOR_CHANGEOVER_NOT_REQUIRED }}"
        method="post"
        novalidate
      >
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
        <button class="govuk-link link-styled-button">{{ __('doNotNeedToDecideItemsForChangeover') }}</button>
      </form>
    </div>
  </div>
{% endblock %}
